      "navigation_kind": "user"
    },
    {
      "id": "user-page",
      "method": "GET",
      "path": "/panel",
      "access": "authenticated",
      "navigable": true,
      "navigation_label": "Panel",
      "navigation_kind": "user"
    },
    {
      "id": "admin-page",
      "method": "GET",
      "path": "/admin",
      "access": "admin",
      "navigable": true,
      "navigation_label": "Admin",
      "navigation_kind": "admin"
    }
  ],
  "assets": [
    {
      "path": "assets/admin.js",
      "content_type": "application/javascript"
    }
  ]
}
