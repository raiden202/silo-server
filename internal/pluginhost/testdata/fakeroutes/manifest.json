      "type": "http_routes.v1",
      "id": "control",
      "display_name": "Control"
    }
  ],
  "user_config_schema": [
    {
      "key": "theme",
      "title": "Theme",
      "json_schema": "{\"type\":\"string\"}",
      "required": true
    }
  ],
  "http_routes": [
    {
      "id": "public-page",
      "method": "GET",
